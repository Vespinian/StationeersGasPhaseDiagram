{
    "name": "stationeersgasphasediagram",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "test": "vitest",
        "deploy": "bun run build && rm -rf dist && mkdir -p dist/StationeersGasPhaseDiagram && cp -r build/* dist/StationeersGasPhaseDiagram/ && cp build/.nojekyll dist/StationeersGasPhaseDiagram/ && npx gh-pages -d dist"
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^7.0.0",
        "@sveltejs/kit": "^2.50.2",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@testing-library/svelte": "^5.3.1",
        "@types/node": "^25.5.2",
        "gh-pages": "^6.3.0",
        "jsdom": "^29.0.1",
        "svelte": "^5.54.0",
        "svelte-check": "^4.4.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "@sveltejs/adapter-static": "^3.0.10",
        "@tailwindcss/vite": "^4.2.2",
        "tailwindcss": "^4.2.2"
    }
}
